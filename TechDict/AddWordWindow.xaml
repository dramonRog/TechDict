<Window x:Class="TechDict.AddWordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Word" Height="200" Width="350" WindowStartupLocation="CenterOwner">

    <Window.Background>
        <ImageBrush ImageSource="/background.jpg" Stretch="UniformToFill"/>
    </Window.Background>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,10">
            <TextBlock Text="English Word:"/>
            <TextBox x:Name="WordBox" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Polish Translation:"/>
            <TextBox x:Name="TranslationBox" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Add" Width="60" Margin="5" Click="Add_Click"/>
            <Button Content="Cancel" Width="60" Margin="5" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
