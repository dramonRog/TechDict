<Window x:Class="TechDict.FlashCardsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Flash Cards" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Background>
        <ImageBrush ImageSource="/background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <StackPanel Margin="20" VerticalAlignment="Top">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Number of Cards:" VerticalAlignment="Center"/>
            <TextBox x:Name="CountTextBox" Width="60" Margin="5,0"/>
            <Label Content="Direction:" VerticalAlignment="Center" Margin="10,0,0,0"/>
            <ComboBox x:Name="DirectionComboBox" Width="120" Margin="5,0">
                <ComboBoxItem Content="English → Polish" IsSelected="True"/>
                <ComboBoxItem Content="Polish → English"/>
            </ComboBox>
            <Button Content="Start" Width="68" Click="StartButton_Click"/>
        </StackPanel>

        <!-- Flashcard Display -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" 
                Padding="30" Margin="0,0,0,10" Background="White"
                MouseLeftButtonUp="CardBorder_MouseLeftButtonUp">
            <TextBlock x:Name="FlashCardText" FontSize="24" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       Text="Click Start" TextWrapping="Wrap"/>
        </Border>

        <!-- Navigation Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="PreviousButton" Content="Previous" Width="100" Margin="10" Click="PrevButton_Click"/>
            <Button x:Name="NextButton" Content="Next" Width="100" Margin="10" Click="NextButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
