<Window x:Class="TechDict.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TechDict" Height="600" Width="800" MinHeight="500" MinWidth="700">

    <Window.Background>
        <ImageBrush ImageSource="\background.jpg" Stretch="UniformToFill"/>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button"> <!-- Zasob Rounded -->
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#999"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
            <Setter.Value>
               <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#f0f0f0"/>
                    <Setter Property="BorderBrush" Value="#666"/>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Import to History" Click="ImportHistory_Click"/>
                <MenuItem Header="Export History" Click="ExportHistory_Click"/>
                <MenuItem Header="Clear History" Click="ClearHistory_Click"/>
                <Separator/>
                <MenuItem Header="About" Click="About_Click"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="Dictionary">
                <MenuItem Header="Open" Click="OpenDictionary_Click"/>
                <MenuItem Header="Add New Word" Click="AddWord_Click"/>
                <MenuItem Header="Save to TXT" Click="SaveDictionary_Click"/>
            </MenuItem>

            <MenuItem Header="Flash Cards" Click="OpenFlashCards_Click"/>
        </Menu>

        <StackPanel Margin="20" VerticalAlignment="Top">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" MinWidth="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label x:Name="InputLabel"
                       Content="English"
                       Background="Transparent"
                       Foreground="Gray"
                       FontWeight="Bold"
                       FontSize="14"
                       Padding="2,0"
                       Margin="10,-10,0,5"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"/>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Background="White">
                        <Grid>
                            <TextBox x:Name="InputTextBox"
                                 Padding="10"
                                 FontSize="18"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 TextChanged="InputTextBox_TextChanged"/>

                            <TextBlock x:Name="PlaceholderText"
                               Text="Enter word..."
                               FontSize="18"
                               Foreground="Gray"
                               Opacity="0.5"
                               Padding="10,10,0,0"
                               IsHitTestVisible="False"
                               Visibility="Visible"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="SuggestionsPopup"
                       PlacementTarget="{Binding ElementName=InputTextBox}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                        <Border Background="White"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="5"
                            MinWidth="{Binding ActualWidth, ElementName=InputTextBox}">
                            <ListBox x:Name="SuggestionsListBox"
                                     FontSize="16"
                                     MaxHeight="150"
                                     SelectionChanged="SuggestionsListBox_SelectionChanged">
                                     PreviewMouseLeftButtonUp="SuggestionsListBox_PreviewMouseLeftButtonUp">    

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="5"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#f0f0f0"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>


                <Grid Grid.Column="2" MinWidth="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label x:Name="OutputLabel"
                           Content="Polish"
                           Background="Transparent"
                           Foreground="Gray"
                           FontWeight="Bold"
                           FontSize="14"
                           Padding="2,0"
                           Margin="10,-10,0,5"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"/>

                    <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Background="White">
                        <TextBox x:Name="OutputTextBox"
                                 Padding="10"
                                 FontSize="18"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="DarkBlue"/>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                <Button Content="Translate"
                        Style="{StaticResource RoundedButton}"
                        Click="Translate_Click"
                        Padding="20,5" MinWidth="60" HorizontalAlignment="Stretch"/>
                <Button Content="↔"
                        Style="{StaticResource RoundedButton}"
                        ToolTip="Swap Languages"
                        MinWidth="30" Height="30" HorizontalAlignment="Stretch"
                        Click="SwapLanguages_Click"/>
                <Button Content="＋"
                        Style="{StaticResource RoundedButton}"
                        ToolTip="Add New Word"
                        MinWidth="30" Height="30" HorizontalAlignment="Stretch"
                        Click="AddWord_Click"/>
                <Button Content="X"
                        MinWidth="30" Height="30" HorizontalAlignment="Stretch"
                        Style="{StaticResource RoundedButton}"
                        ToolTip="Clear both boxes"
                        Click="ClearInput_Click"/>
            </StackPanel>

            <Border BorderBrush="#999" BorderThickness="1" CornerRadius="5" Background="White" MinHeight="100" Margin="1">
                <ListBox x:Name="HistoryListBox"
                         FontSize="16"
                         Height="150"
                         BorderThickness="0"
                         SelectionChanged="HistoryListBox_SelectionChanged"/>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
